# @supabase/storage-js is a transitive dependency of @supabase/supabase-js.
# Hoisting it to the top-level node_modules allows TypeScript to resolve its
# types by a stable package name, preventing TS2742 ("inferred type cannot be
# named without a reference to .pnpm/...") on the Storage service class.
public-hoist-pattern[]=@supabase/storage-js
public-hoist-pattern[]=@supabase/supabase-js
public-hoist-pattern[]=@supabase/postgrest-js
