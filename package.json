{
  "name": "supabase-effect",
  "type": "module",
  "version": "0.4.2",
  "description": "An Effect-ts wrapper for supabase",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./client": {
      "import": "./dist/client.js",
      "types": "./dist/client.d.ts"
    },
    "./postgrest": {
      "import": "./dist/postgrest.js",
      "types": "./dist/postgrest.d.ts"
    },
    "./auth": {
      "import": "./dist/auth.js",
      "types": "./dist/auth.d.ts"
    },
    "./auth-error": {
      "import": "./dist/auth-error.js",
      "types": "./dist/auth-error.d.ts"
    },
    "./postgrest-error": {
      "import": "./dist/postgrest-error.js",
      "types": "./dist/postgrest-error.d.ts"
    },
    "./postgrest-response": {
      "import": "./dist/pg-response.js",
      "types": "./dist/pg-response.d.ts"
    },
    "./storage": {
      "import": "./dist/storage.js",
      "types": "./dist/storage.d.ts"
    },
    "./storage-error": {
      "import": "./dist/storage-error.js",
      "types": "./dist/storage-error.d.ts"
    },
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "rm -f tsconfig.tsbuildinfo && tsc",
    "watch": "tsc --watch",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "typecheck:test": "vitest --typecheck.enabled --run",
    "typecheck:all": "pnpm typecheck && pnpm test",
    "lint": "eslint src",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "prepublishOnly": "pnpm run clean && pnpm run build"
  },
  "keywords": [
    "effect",
    "effect-ts",
    "supabase",
    "typescript",
    "functional-programming"
  ],
  "author": "Jungin Yu <jungini1226@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/alphaiv-project/supabase-effect"
  },
  "packageManager": "pnpm@10.29.2",
  "engines": {
    "node": ">=18.0.0"
  },
  "pnpm": {
    "overrides": {
      "@supabase/supabase-js": "^2.99.0"
    }
  },
  "peerDependencies": {
    "@supabase/storage-js": "^2.0.0",
    "@supabase/supabase-js": "^2.0.0",
    "effect": "^4.0.0"
  },
  "devDependencies": {
    "@effect/language-service": "^0.85.0",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.3",
    "prettier": "^3.4.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.99.0",
    "effect": "4.0.0-beta.60"
  }
}
